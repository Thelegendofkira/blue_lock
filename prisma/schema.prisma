// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------

enum Status {
  ACTIVE
  PAUSED
  STOPPED
  COMPLETED
}

enum EffortType {
  DEEP_WORK      
  SHALLOW_WORK   
  NO_EFFORT      
  NOT_APPLICABLE 
}

enum BlockType {
  TASK_EXECUTION
  SLEEP
  COLLEGE
  DISTRACTION
}

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed
  createdAt DateTime @default(now())

  nodes     GoalNode[]
  dailyLogs DailyLog[]
}

model GoalNode {
  id              String   @id @default(cuid())
  userId          String
  title           String
  reason          String   
  deadline        DateTime 
  
  parentId        String?
  parent          GoalNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children        GoalNode[] @relation("NodeHierarchy")

  status          Status     @default(ACTIVE)
  activatedAt     DateTime   @default(now())
  deactivatedAt   DateTime?  

  isTask          Boolean    @default(false) 
  effortType      EffortType @default(NOT_APPLICABLE)
  
  quantifierUnit  String?    
  targetQuantity  Float?     
  currentQuantity Float      @default(0)
  estimatedTime   Float?     // Total estimated hours

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyLogs       DailyLog[]

  @@index([userId])
  @@index([parentId])
}

model DailyLog {
  id              String     @id @default(cuid())
  userId          String
  
  date            DateTime   
  hourBlock       Int        
  blockType       BlockType  
  
  // Notice focusState is completely gone
  taskId          String?    
  valueAchieved   Float?     
  timeSpent       Float?     
  notes           String?    @db.Text 

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            GoalNode?  @relation(fields: [taskId], references: [id])

  @@index([userId, date])
}