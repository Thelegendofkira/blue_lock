// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ----------------------------------------------------
// ENUMS: The strict rules of the application
// ----------------------------------------------------

enum Status {
  ACTIVE
  PAUSED
  STOPPED
  COMPLETED
}

enum EffortType {
  DEEP_WORK      // Max 4 hrs/day
  SHALLOW_WORK   // Max 2 hrs/day
  NO_EFFORT      // No limit, but total day < 12 hrs
  NOT_APPLICABLE // For high-level goals that aren't leaf tasks
}

enum BlockType {
  TASK_EXECUTION
  SLEEP
  COLLEGE
}

enum FocusState {
  FOCUSED
  DISTRACTED
  N_A // For Sleep/College blocks
}

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed
  createdAt DateTime @default(now())

  nodes     GoalNode[]
  dailyLogs DailyLog[]
}

model GoalNode {
  id              String   @id @default(cuid())
  userId          String
  title           String
  reason          String   
  deadline        DateTime 
  
  parentId        String?
  parent          GoalNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children        GoalNode[] @relation("NodeHierarchy")

  status          Status     @default(ACTIVE)
  activatedAt     DateTime   @default(now())
  deactivatedAt   DateTime?  

  // --- UPGRADED TASK VARIABLES ---
  isTask          Boolean    @default(false) // Explicitly defines if it's a Goal or Task
  effortType      EffortType @default(NOT_APPLICABLE)
  
  quantifierUnit  String?    // e.g., "LeetCode Problems", "Pages", "Commits"
  targetQuantity  Float?     // The number they are trying to hit
  currentQuantity Float      @default(0)
  
  estimatedTime   Float?     // Estimated total hours to complete this task
  // -------------------------------

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyLogs       DailyLog[]

  @@index([userId])
  @@index([parentId])
}

model DailyLog {
  id              String     @id @default(cuid())
  userId          String
  
  date            DateTime   
  hourBlock       Int        // 0 to 23 
  
  blockType       BlockType  
  focusState      FocusState @default(N_A)
  
  // --- UPGRADED LOG VARIABLES ---
  taskId          String?    
  valueAchieved   Float?     // Quantity achieved (e.g., 3 problems)
  timeSpent       Float?     // Time spent in HOURS (e.g., 0.5 = 30 mins)
  notes           String?    @db.Text // The verbal descriptor / mini-journal
  // ------------------------------

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            GoalNode?  @relation(fields: [taskId], references: [id])

  // REMOVED: @@unique([userId, date, hourBlock]) 
  // We removed the unique constraint so you can log multiple tasks in the same hour block!
  
  @@index([userId, date])
}